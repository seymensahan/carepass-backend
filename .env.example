# ── Server ──────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database (Neon PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/carepass?sslmode=require

# ── JWT Authentication ─────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Appwrite Storage ──────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key
APPWRITE_BUCKET_ID=carepass-files

# ── Email (Resend) ────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="CAREPASS <noreply@carepass.cm>"

# ── Frontend URL (for email links) ───────────────
FRONTEND_URL=http://localhost:3000

# ── Payments (Pawapay Mobile Money) ──────────────
PAWAPAY_API_URL=https://api.sandbox.pawapay.io
PAWAPAY_API_KEY=your-pawapay-api-key

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Rate Limiting ─────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
